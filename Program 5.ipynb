   "source": [
    "# Write a program to find the largest of three numbers."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "b1b57c5d-2e10-4b90-8855-e459ad22a2ac",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      " 1 2 0\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "B is Largest Number\n"
     ]
    }
   ],
   "source": [
    "a, b, c = list(map(int, input().split()))\n",
    "if a > b and a > c:\n",
    "    print(\"A is Largest Number\")\n",
    "elif b > c:\n",
    "    print(\"B is Largest Number\")\n",
    "else:\n",
    "    print(\"C is Largest Number\")"
   ]
  },
