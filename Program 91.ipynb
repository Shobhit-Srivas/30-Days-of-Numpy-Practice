   "source": [
    "# Create a script to convert binary string to decimal."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "bf965850-a9d5-4e86-a401-3bf61a249ea4",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a binary number:  110\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Decimal number is: 6\n"
     ]
    }
   ],
   "source": [
    "binary = input(\"Enter a binary number: \")\n",
    "decimal = 0\n",
    "power = 0\n",
    "for digit in binary[::-1]:\n",
    "    decimal += int(digit) * (2 ** power)\n",
    "    power += 1\n",
    "print(\"Decimal number is:\", decimal)"
   ]
  },
