   "source": [
    "# Convert a decimal number to binary using loops."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "0e1d5519-1bb0-42b2-a52b-fa44895c1a39",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a decimal number:  5\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Binary Number is: 101\n"
     ]
    }
   ],
   "source": [
    "num = int(input(\"Enter a decimal number: \"))\n",
    "binary = \"\"\n",
    "while num != 0:\n",
    "    r = num % 2\n",
    "    binary = str(r) + binary\n",
    "    num = num // 2\n",
    "print(\"Binary Number is:\", binary)"
   ]
  }
 ],
