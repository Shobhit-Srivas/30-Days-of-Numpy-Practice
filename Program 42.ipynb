   "source": [
    "# Create a program to check if a key exists in a dictionary."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "1b8fa347-75da-4e21-9d52-0b99f565c22f",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Key exists\n"
     ]
    }
   ],
   "source": [
    "student = {\n",
    "    \"name\": \"Shobhit\",\n",
    "    \"age\": 21,\n",
    "    \"course\": \"Python\"\n",
    "}\n",
    "if \"age\" in student:\n",
    "    print(\"Key exists\")\n",
    "else:\n",
    "    print(\"Key does not exist\")"
   ]
  }
