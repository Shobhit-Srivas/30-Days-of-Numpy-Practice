   "source": [
    "# Write a program to calculate the average word length in a sentence."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "d7225fd6-2c5c-473d-abaf-de01e61ee7e6",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a sentence:  this is a pen and that is a ball\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Average word length: 2.6666666666666665\n"
     ]
    }
   ],
   "source": [
    "sentence = input(\"Enter a sentence: \")\n",
    "words = sentence.split()\n",
    "total_length = 0\n",
    "for word in words:\n",
    "    total_length += len(word)\n",
    "average = total_length / len(words)\n",
    "print(\"Average word length:\", average)"
   ]
  },
