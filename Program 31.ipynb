   "source": [
    "# Write a function to check if a number is even."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "c9fe8a47-fcd7-4f4d-b3f0-aa7f55a7a82b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a number:  5\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Odd Number\n"
     ]
    }
   ],
   "source": [
    "def CheckEvenOdd(n):\n",
    "    if n % 2 == 0:\n",
    "        print(\"Even Number\")\n",
    "    else:\n",
    "        print(\"Odd Number\")\n",
    "n = int(input(\"Enter a number: \"))\n",
    "CheckEvenOdd(n)"
   ]
  }
 ],
