   "source": [
    "# Write a Python script to sort words in a sentence alphabetically."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "ad970445-d8d7-44e1-b4b2-8fe2d26c310c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a sentence:  SLSKL lslk lsd KDF\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Words in alphabetical order:\n",
      "KDF\n",
      "SLSKL\n",
      "lsd\n",
      "lslk\n"
     ]
    }
   ],
   "source": [
    "sentence = input(\"Enter a sentence: \")\n",
    "words = sentence.split()\n",
    "words.sort()\n",
    "print(\"Words in alphabetical order:\")\n",
    "for word in words:\n",
    "    print(word)"
   ]
  },
