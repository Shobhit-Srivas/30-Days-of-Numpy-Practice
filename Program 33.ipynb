   "source": [
    "# Write a program to find the maximum and minimum in a list."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "8c7fb742-ce56-4bb3-91b7-8d1211b8dc94",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter numbers seperated by space:  1 2 3 4 5\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Maximum number is 5\n",
      "Minmum number is 1\n"
     ]
    }
   ],
   "source": [
    "def MaxMin(arr):\n",
    "    print(f\"Maximum number is {max(arr)}\")\n",
    "    print(f\"Minmum number is {min(arr)}\")\n",
    "    \n",
    "numbers = list(map(int, input(\"Enter numbers seperated by space: \").split()))\n",
    "MaxMin(numbers)"
   ]
  }
 ],
