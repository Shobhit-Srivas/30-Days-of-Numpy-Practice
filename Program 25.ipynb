     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Original Matrix Array is\n",
      ": [[1 2 3]\n",
      " [4 5 6]\n",
      " [7 8 9]]\n",
      "Mean of each row is\n",
      ": [2. 5. 8.]\n",
      "Mean of each column is\n",
      ": [4. 5. 6.]\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "arr = np.arange(1, 10).reshape(3, 3)\n",
    "print(f\"Original Matrix Array is\\n: {arr}\")\n",
    "print(f\"Mean of each row is\\n: {np.mean(arr, axis = 1)}\")\n",
    "print(f\"Mean of each column is\\n: {np.mean(arr, axis = 0)}\")"
   ]
  },
