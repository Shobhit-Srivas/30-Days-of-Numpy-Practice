   "source": [
    "# Write a program to count the number of digits in an integer"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "43791b13-eb9d-4f2b-a45b-07ec66849351",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a number:  123\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Total digits of an integer is 3\n"
     ]
    }
   ],
   "source": [
    "num = int(input(\"Enter a number: \"))\n",
    "total = 0\n",
    "while num != 0:\n",
    "    total += 1\n",
    "    num //= 10\n",
    "print(f\"Total digits of an integer is {total}\")"
   ]
  }
 ],
