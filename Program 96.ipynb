   "source": [
    "# Write a program to find all palindromic substrings in a string."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "99445210-d449-4b8c-a2e2-6a8284a006cc",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a string:  this is a jahaj with madam\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "All Palindromic Substrings are ['a', 'jahaj', 'madam']\n"
     ]
    }
   ],
   "source": [
    "string = input(\"Enter a string: \")\n",
    "words = string.split()\n",
    "lst = []\n",
    "for word in words:\n",
    "    if word == word[::-1]:\n",
    "       lst.append(word)\n",
    "print(f\"All Palindromic Substrings are {lst}\")"
   ]
  },
