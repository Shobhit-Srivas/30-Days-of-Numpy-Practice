   "source": [
    "# Write a program that extracts all integers from a given text."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "5d3f6398-a22c-4f0b-af95-fb420292e0eb",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Integers found: [25, 98, 2026]\n"
     ]
    }
   ],
   "source": [
    "import re\n",
    "text = \"John is 25 years old and scored 98 marks in 2026.\"\n",
    "numbers = re.findall(r\"\\d+\", text)\n",
    "numbers = [int(num) for num in numbers]\n",
    "print(\"Integers found:\", numbers)"
   ]
  },
