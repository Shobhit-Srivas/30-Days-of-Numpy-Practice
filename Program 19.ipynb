   "source": [
    "# Create a 3×3 matrix and print the third column."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "7aa8e90b-ae72-448c-bc13-d3297d795e79",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Original Array is\n",
      ": [[1 2 3]\n",
      " [4 5 6]\n",
      " [7 8 9]]\n",
      "Third Column of Matrix is\n",
      ": [3 6 9]\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "arr = np.arange(1, 10).reshape(3, 3)\n",
    "print(f\"Original Array is\\n: {arr}\")\n",
    "print(f\"Third Column of Matrix is\\n: {arr[:, 2]}\")"
   ]
