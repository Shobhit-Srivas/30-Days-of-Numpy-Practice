   "source": [
    "# Write a Python program to split a sentence into words and reverse each word."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "21780204-e6b8-4d9b-87d3-e29797fb6c9a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a sting:  this is a pen\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "siht si a nep \n"
     ]
    }
   ],
   "source": [
    "string = input(\"Enter a sting: \")\n",
    "words = string.split()\n",
    "st = \"\"\n",
    "for word in words:\n",
    "    st += word[::-1]\n",
    "    st += \" \"\n",
    "print(st)"
   ]
  },
