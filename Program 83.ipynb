   "source": [
    "# Write a function to count how many times a substring appears in a string."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "368c4d71-b519-4507-b49b-5fbbe73feb67",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a string:  this is a pen that is a ball\n",
      "Enter a sub string:  is\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Total Count of substring is 3\n"
     ]
    }
   ],
   "source": [
    "def Count(string, substr):\n",
    "    return string.count(substr)\n",
    "\n",
    "\n",
    "st = input(\"Enter a string: \")\n",
    "sub = input(\"Enter a sub string: \")\n",
    "print(f\"Total Count of substring is {Count(st, sub)}\")"
   ]
  },
