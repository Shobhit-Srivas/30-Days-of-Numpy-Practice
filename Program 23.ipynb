   "source": [
    "# Transpose a 3×2 matrix."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "3783032e-8e43-4e25-ae03-d6440d0f2a01",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Original Matrix is\n",
      ": [[1 2]\n",
      " [3 4]\n",
      " [5 6]]\n",
      "Transpose of Matrix is\n",
      ": [[1 3 5]\n",
      " [2 4 6]]\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "arr = np.arange(1, 7).reshape(3, 2)\n",
    "transpose_arr = arr.T\n",
    "print(f\"Original Matrix is\\n: {arr}\")\n",
    "print(f\"Transpose of Matrix is\\n: {transpose_arr}\")"
   ]
  },
