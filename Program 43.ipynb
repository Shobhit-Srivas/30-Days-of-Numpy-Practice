   "source": [
    "# Create a set and perform union, intersection, and difference."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "b8c8da83-62db-4c6b-bccb-b9d7a90eaf22",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Union is: {1, 2, 3, 4, 5, 6, 33, 10, 45, 20}\n",
      "Intersection is: {1, 2, 3, 4, 6}\n",
      "Difference is: {5}\n"
     ]
    }
   ],
   "source": [
    "Set1 = {1,2,3,4,5,1,2,3,6}\n",
    "Set2 = {10,20,33,4,45,1,2,3,6}\n",
    "print(f\"Union is: {Set1.union(Set2)}\")\n",
    "print(f\"Intersection is: {Set1.intersection(Set2)}\")\n",
    "print(f\"Difference is: {Set1.difference(Set2)}\")"
   ]
  }
