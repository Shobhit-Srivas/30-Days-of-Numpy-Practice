   "source": [
    "# Write a function to capitalize the first letter of each word in a string."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "298fd543-88fc-422c-ae12-93c44b22bb15",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a string:  hey i am a good man\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Hey I Am A Good Man\n"
     ]
    }
   ],
   "source": [
    "def Capitalize(string):\n",
    "    st = string.title()\n",
    "    print(st)\n",
    "\n",
    "st = input(\"Enter a string: \")\n",
    "Capitalize(st)"
   ]
  }
