   "source": [
    "# Find the determinant of a 2×2 matrix."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "5b4da226-8bc8-4493-94d2-dd7a0c37e4b7",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Original Matrix is\n",
      ": [[4 7]\n",
      " [2 6]]\n",
      "Determinant is: 10.000000000000002\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "arr = np.array([[4, 7], [2, 6]])\n",
    "det = np.linalg.det(arr)\n",
    "print(f\"Original Matrix is\\n: {arr}\")\n",
    "print(f\"Determinant is: {det}\")"
   ]
  },
