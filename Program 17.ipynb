   "source": [
    "# Write a program to find the LCM of two numbers."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "4932c437-ac3b-4359-b487-827e2afcb318",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      " 12 18\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "The LCM of two number is 36\n"
     ]
    }
   ],
   "source": [
    "import math\n",
    "a, b = list(map(int, input().split()))\n",
    "lcm = (a*b) // math.gcd(a,b)\n",
    "print(f\"The LCM of two number is {lcm}\")"
   ]
  }
