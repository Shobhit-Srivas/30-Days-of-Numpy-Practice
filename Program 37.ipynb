   "source": [
    "def Convert(arr):\n",
    "    t = tuple(arr)\n",
    "    print(t)\n",
    "    l = list(t)\n",
    "    print(l)\n",
    "    \n",
    "numbers = list(map(int, input(\"Enter number seperated by space: \").split()))\n",
    "Convert(numbers)"
   ]
  }
