   "source": [
    "# Write a script to convert a string into title case without using .title()."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "3d09468f-ee00-41de-bbe7-6259cbfb5a4e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a string:  this is a pen\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "This Is A Pen \n"
     ]
    }
   ],
   "source": [
    "string = input(\"Enter a string: \")\n",
    "words = string.split(\" \")\n",
    "st = \"\"\n",
    "for word in words:\n",
    "    st += word[0].upper() + word[1:].lower()\n",
    "    st += \" \"\n",
    "print(st)"
   ]
  },
