   "source": [
    "student = {\n",
    "    \"name\": \"Shobhit\",\n",
    "    \"age\": 21,\n",
    "    \"course\": \"Python\"\n",
    "}\n",
    "for key, value in student.items():\n",
    "    print(key, \":\", value)"
   ]
