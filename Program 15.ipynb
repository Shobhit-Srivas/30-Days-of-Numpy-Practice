   "source": [
    "# Create a program to print the Fibonacci series up to N terms."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "43c0dd70-f97e-438c-92d9-808deca768eb",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a number:  8\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "0 1 1 2 3 5 8 13 "
     ]
    }
   ],
   "source": [
    "n = int(input(\"Enter a number: \"))\n",
    "a , b = 0, 1\n",
    "print(a,end= \" \")\n",
    "print(b,end= \" \")\n",
    "for i in range(n-2):\n",
    "    sum = a+b\n",
    "    a = b\n",
    "    b = sum\n",
    "    print(sum, end=\" \")"
   ]
  }
 ],
