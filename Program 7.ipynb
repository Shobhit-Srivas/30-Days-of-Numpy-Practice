   "source": [
    "# Write a program to calculate the factorial of a number using a loop."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "d9cfebc2-5bf0-4ea4-a40f-a68ef99c7d79",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a number:  5\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Factorial of 5 is 120\n"
     ]
    }
   ],
   "source": [
    "n = int(input(\"Enter a number: \"))\n",
    "f = 1\n",
    "for i in range(1, n+1):\n",
    "    f *= i\n",
    "print(f\"Factorial of {n} is {f}\")"
   ]
  }
 ],
