   "source": [
    "# Write a program that counts the occurrence of each vowel in a paragraph."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "3263257f-6514-42a0-80f0-d405bf857e26",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a string:  this is a epne\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Total vowel is 5\n"
     ]
    }
   ],
   "source": [
    "string = input(\"Enter a string: \")\n",
    "count = 0\n",
    "for ch in string:\n",
    "    if ch == 'a' or ch == 'e' or ch == 'i' or ch == 'o' or ch == 'u':\n",
    "        count += 1\n",
    "print(f\"Total vowel is {count}\")"
   ]
  },
