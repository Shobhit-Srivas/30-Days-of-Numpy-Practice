   "source": [
    "import random\n",
    "n = int(input(\"Enter a number from 1 to 100: \"))\n",
    "num = random.randint(1,100)\n",
    "if num == n:\n",
    "    print(\"Guess Number is Correct\")\n",
    "else:\n",
    "    print(\"Guess Number is not Correct\")"
   ]
