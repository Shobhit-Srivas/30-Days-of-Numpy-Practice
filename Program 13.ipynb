     ]
    }
   ],
   "source": [
    "for i in range(2,100):\n",
    "    f = 0\n",
    "    for j in range(2,int(i**0.5) + 1):\n",
    "        if i % j == 0:\n",
    "            f = 1\n",
    "            break\n",
    "    if f == 0:\n",
    "        print(f\"{i} is a Prime Number\")"
   ]
  }
