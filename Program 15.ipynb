   "source": [
    "# Create a NumPy array from the list [10, 20, 30, 40, 50]."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "9a1b5e0a-42bc-4889-ab50-cba315c722db",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Original List is: [10, 20, 30, 40, 50]\n",
      "Numpy Array from the List is: [10 20 30 40 50]\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "lst = [10, 20, 30, 40, 50]\n",
    "print(f\"Original List is: {lst}\")\n",
    "arr = np.array(lst)\n",
    "print(f\"Numpy Array from the List is: {arr}\")"
   ]
