   "source": [
    "# Write a program to remove all None values from a list."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "503b1518-1421-4cec-806c-8bf820c49945",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Updated List: [1, 2, 3, 4]\n"
     ]
    }
   ],
   "source": [
    "my_list = [1, None, 2, None, 3, 4, None]\n",
    "new_list = [x for x in my_list if x is not None]\n",
    "print(\"Updated List:\", new_list)"
   ]
