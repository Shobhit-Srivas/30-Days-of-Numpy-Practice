   "source": [
    "# Create a script to find duplicate words in a paragraph."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "60143963-ca1d-4c71-8ede-e98a30c0641c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a paragraph string is so is pop so\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "is\n",
      "so\n"
     ]
    }
   ],
   "source": [
    "string = input(\"Enter a paragraph\")\n",
    "seen = {}\n",
    "words = string.split()\n",
    "for word in words:\n",
    "    if word not in seen:\n",
    "        seen[word] = 1\n",
    "    else:\n",
    "        seen[word] += 1\n",
    "for k, v in seen.items():\n",
    "    if v > 1:\n",
    "        print(k)"
   ]
  },
