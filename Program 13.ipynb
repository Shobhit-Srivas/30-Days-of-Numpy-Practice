   "source": [
    "# Write a program to print all prime numbers between 1 and 100."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "856c0f3b-820b-435b-ac84-77c6b3a44f1c",
   "metadata": {},
