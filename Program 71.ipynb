   "source": [
    "# Write a Python program to check if a string has all unique characters."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "fe4526ca-03a6-4a6a-adac-a41aed7c7afe",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a string:  Aman\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Not all unique characters\n"
     ]
    }
   ],
   "source": [
    "string = input(\"Enter a string: \")\n",
    "st = set(string.lower())\n",
    "if len(string) == len(st):\n",
    "    print(\"All unique Characters\")\n",
    "else:\n",
    "    print(\"Not all unique characters\")"
   ]
  },
