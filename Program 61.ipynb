   "source": [
    "# Write a Python script to read a file and print its contents."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "a66accf1-fa5b-4ed9-9dca-92c3e87de823",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "File does not exist\n"
     ]
    }
   ],
   "source": [
    "try:\n",
    "    file = open(\"sample.txt\", \"r\")\n",
    "    content = file.read()\n",
    "    print(content)\n",
    "    file.close()\n",
    "except FileNotFoundError:\n",
    "    print(\"File does not exist\")"
   ]
