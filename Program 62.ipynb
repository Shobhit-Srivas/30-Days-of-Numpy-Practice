   "source": [
    "try:\n",
    "    file = open(\"name.txt\", \"w\")\n",
    "    file.write(\"Shobhit Srivastava\")\n",
    "    file.close()\n",
    "    print(\"Name written successfully\")\n",
    "except FileNotFoundError:\n",
