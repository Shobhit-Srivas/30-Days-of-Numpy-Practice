   "source": [
    "# Create a program to count the number of vowels in a string."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "14f285d7-ed31-4a67-8fdd-66becd48c403",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a string:  aman\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Total vowels found is 2\n"
     ]
    }
   ],
   "source": [
    "string = input(\"Enter a string: \")\n",
    "count = 0\n",
    "string.lower()\n",
    "for i in string:\n",
    "    if i == 'a' or i == 'e' or i == 'i' or i == '0' or i == 'u':\n",
    "        count += 1\n",
    "print(f\"Total vowels found is {count}\")"
   ]
  }
 ],
