   "source": [
    "# Write a Python program to count the frequency of each word in a string."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "db0485b0-6ad1-4989-b2fc-7088d576d335",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a sting:  this is a pen and that is a pen\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "{'this': 1, 'is': 2, 'a': 2, 'pen': 2, 'and': 1, 'that': 1}\n"
     ]
    }
   ],
   "source": [
    "string = input(\"Enter a sting: \")\n",
    "words = string.split()\n",
    "seen = {}\n",
    "for word in words:\n",
    "    if word not in seen:\n",
    "        seen[word] = 1\n",
    "    else:\n",
    "        seen[word] += 1\n",
    "print(seen)"
   ]
  },
