   "source": [
    "# Create a program to check whether a number is prime or not."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "746b08e1-d67a-4588-a08c-40127934552b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a number:  21\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Number is not Prime\n"
     ]
    }
   ],
   "source": [
    "num = int(input(\"Enter a number: \"))\n",
    "f = 0\n",
    "for i in range(2, num):\n",
    "    if num % i == 0:\n",
    "        f = 1\n",
    "        break\n",
    "if f == 0 and num != 1:\n",
    "    print(\"Number is Prime\")\n",
    "else:\n",
    "    print(\"Number is not Prime\")"
   ]
  }
 ],
