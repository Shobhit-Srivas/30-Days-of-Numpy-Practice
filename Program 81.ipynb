   "source": [
    "# Create a program that extracts numbers from a string and returns their sum."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "7df94f3c-4168-4284-be6c-85592b9f0bc6",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a string:  String1452sd\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Total sum of 12\n"
     ]
    }
   ],
   "source": [
    "string = input(\"Enter a string: \")\n",
    "total = 0\n",
    "for ch in string:\n",
    "    if ch.isnumeric():\n",
    "        total += int(ch)\n",
    "print(f\"Total sum of {total}\")"
   ]
  },
