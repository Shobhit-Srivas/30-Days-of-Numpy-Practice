   "source": [
    "# Create a list comprehension to get squares of all even numbers in a range."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "06fd1029-57e8-4504-b38a-3ab253f12994",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[4, 16, 36, 64, 100]\n"
     ]
    }
   ],
   "source": [
    "squares = [x**2 for x in range(1, 11) if x % 2 == 0]\n",
    "print(squares)"
   ]
