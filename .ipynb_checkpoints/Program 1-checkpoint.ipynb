   "source": [
    "# Write a Python program to swap two variables."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "e4360d35-1050-44c0-91cc-8c6ad6f5188d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter First Number:  12\n",
      "Enter Second Number:  25\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Before Swap Values a = 12 and b = 25\n",
      "After Swap Values a= 25 and b = 12\n"
     ]
    }
   ],
   "source": [
    "a = int(input(\"Enter First Number: \"))\n",
    "b = int(input(\"Enter Second Number: \"))\n",
    "print(f\"Before Swap Values a = {a} and b = {b}\")\n",
    "t = a\n",
    "a = b\n",
    "b = t\n",
    "print(f\"After Swap Values a= {a} and b = {b}\")"
   ]
  }
