   "source": [
    "# Write a generator that yields even numbers up to N."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "4c34def3-4d96-4f07-92f0-b310ad96ef0a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "2\n",
      "4\n",
      "6\n",
      "8\n",
      "10\n"
     ]
    }
   ],
   "source": [
    "def even_numbers(n):\n",
    "    for i in range(1, n + 1):\n",
    "        if i % 2 == 0:\n",
    "            yield i\n",
    "\n",
    "for num in even_numbers(10):\n",
    "    print(num)"
   ]
  },
