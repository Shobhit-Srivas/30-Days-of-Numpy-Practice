   "source": [
    "# Write a program to find the GCD of two numbers."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "7bf64461-f7c5-49b9-b615-78fbbd094d9d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      " 48 18\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "GCD of two number is 6\n"
     ]
    }
   ],
   "source": [
    "a, b = list(map(int, input().split()))\n",
    "while b != 0:\n",
    "    a, b = b, a%b\n",
    "print(f\"GCD of two number is {a}\")"
   ]
  }
