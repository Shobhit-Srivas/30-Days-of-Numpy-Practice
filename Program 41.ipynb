   "source": [
    "# Write a program to sort a list in ascending order."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "0480b3ce-b0ae-4117-ae2a-8bd9891f29e5",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter numbers seperated by space:  1 5 9 3 6 8 4\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[1, 3, 4, 5, 6, 8, 9]\n"
     ]
    }
   ],
   "source": [
    "def Sort(arr):\n",
    "    arr.sort()\n",
    "    print(arr)\n",
    "\n",
    "numbers = list(map(int, input(\"Enter numbers seperated by space: \").split()))\n",
    "Sort(numbers)"
   ]
  }
 ],
