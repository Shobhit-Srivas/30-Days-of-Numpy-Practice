     "text": [
      "Enter a string:  Shobhit Srivastava\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Shobhit_Srivastava\n"
     ]
    }
   ],
   "source": [
    "string = input(\"Enter a string: \")\n",
    "string = string.replace(\" \",\"_\")\n",
    "print(string)"
