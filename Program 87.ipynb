   "source": [
    "# Write a function that returns True if a string ends with a given suffix."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "5f866a50-44b0-4006-a3ea-c4bcdba42aa0",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a string:  string\n",
      "Enter a suffix:  ing\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "True\n"
     ]
    }
   ],
   "source": [
    "def String(st, suf):\n",
    "    return st.endswith(suf)\n",
    "\n",
    "st = input(\"Enter a string: \")\n",
    "suf = input(\"Enter a suffix: \")\n",
    "print(String(st,suf))"
   ]
  },
