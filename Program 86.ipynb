   "source": [
    "# Create a program to filter out all non-alphabetic characters from a string."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "cddefabc-1354-4d73-a92b-4f7c1807e637",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a string:  str16sri\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "strsri\n"
     ]
    }
   ],
   "source": [
    "string = input(\"Enter a string: \")\n",
    "st = \"\"\n",
    "for ch in string:\n",
    "    if ch.isalpha():\n",
    "        st += ch\n",
    "print(st)"
   ]
  },
