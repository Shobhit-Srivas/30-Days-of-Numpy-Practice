   "source": [
    "# Write a script that extracts hashtags from a tweet."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "b1c8fbb7-3c9b-4d5c-a839-fa874ea6c8f3",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a tweet:  #python and #c and #mohit\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Hashtags found:\n",
      "['#python', '#c', '#mohit']\n"
     ]
    }
   ],
   "source": [
    "tweet = input(\"Enter a tweet: \")\n",
    "words = tweet.split()\n",
    "hashtags = []\n",
    "for word in words:\n",
    "    if word.startswith(\"#\"):\n",
    "        hashtags.append(word)\n",
    "print(\"Hashtags found:\")\n",
    "print(hashtags)"
   ]
  },
