   "source": [
    "# Write a program to find the sum of first N natural numbers."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "68db263c-315b-43ef-9b76-d6030c53d5a4",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a number:  5\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "The sum of First N natural Number is 15\n"
     ]
    }
   ],
   "source": [
    "n = int(input(\"Enter a number: \"))\n",
    "total = 0\n",
    "for i in range(1,n+1):\n",
    "    total += i\n",
    "print(f\"The sum of First N natural Number is {total}\")"
   ]
  }
 ],
