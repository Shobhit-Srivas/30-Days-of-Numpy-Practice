   "source": [
    "# Create a list and find the sum of all its elements."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "9249d5a2-e29d-418d-aa97-f877b11a3b3f",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter numbers seperated by space:  1 2 3 4 5\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Sum of all elements is 15\n"
     ]
    }
   ],
   "source": [
    "def Sum(arr):\n",
    "    total = 0\n",
    "    for n in arr:\n",
    "        total += n\n",
    "    print(f\"Sum of all elements is {total}\")\n",
    "numbers = list(map(int, input(\"Enter numbers seperated by space: \").split()))\n",
    "Sum(numbers)"
   ]
  }
 ],
