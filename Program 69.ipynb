   "source": [
    "# Write a program to read a CSV file and print its contents."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "de1de5a0-50da-4174-b683-d3b032ce65a6",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "File does not exit:\n"
     ]
    }
   ],
   "source": [
    "import csv\n",
    "try:\n",
    "    file = open(\"data.csv\", \"r\")\n",
    "    csv_reader = csv.reader(file)\n",
    "    for row in csv_reader:\n",
    "        print(row)    \n",
    "    file.close()\n",
    "except FileNotFoundError:\n",
    "    print(\"File does not exit:\")"
   ]
  },
