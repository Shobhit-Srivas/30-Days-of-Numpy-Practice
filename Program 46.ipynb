   "source": [
    "# Create a function that checks whether a string is a palindrome."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "ded5989d-4637-4e8c-bb7e-8e2c0db93a69",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a string:  aman\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Not Palindrome String\n"
     ]
    }
   ],
   "source": [
    "def Palindrome(string):\n",
    "    if string == string[::-1]:\n",
    "        print(\"Palindrome String\")\n",
    "    else:\n",
    "        print(\"Not Palindrome String\")\n",
    "    \n",
    "st = input(\"Enter a string: \")\n",
    "Palindrome(st)"
   ]
  }
 ],
